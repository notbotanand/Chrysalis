# All card content is intentionally tracked. Temp cards are committed so
# CoWork push works cleanly. The exceptions below are auto-generated artifacts
# and credentials — neither belongs in git history.

# Secrets
*.env
.env

# Generated dashboard (regenerated from data/ on every brief)
dashboard.html

# Python bytecode cache (auto-generated by framework/tools/*.py)
__pycache__/
*.pyc

# Private-only release scanner config — never publish.
# Lives only on the maintainer's machine. The cut tool reads it from the
# private repo and uses it as a fail-loud PII scanner over the public output.
framework/release-tools/.release-denylist.yaml
